@inherits LayoutComponentBase
@using Blazor.Heroicons.Outline
@inject SettingsService SettingsService
@inject DownloadService DownloadService
@inject NavigationManager Nav
@implements IDisposable

<div class="flex h-screen">
    <nav class="w-52 bg-neutral text-neutral-content flex flex-col shrink-0">
        <div class="px-5 py-4 border-b border-neutral-content/10">
            <span class="font-semibold text-sm">Cinemabox</span>
        </div>

        <div class="flex flex-col gap-0.5 px-2 py-3 flex-1">
            <NavLink href="/" Match="NavLinkMatch.All"
                     class="flex items-center gap-2.5 px-3 py-2 rounded text-sm text-neutral-content/60 hover:text-neutral-content hover:bg-neutral-content/10 transition-colors"
                     ActiveClass="!text-neutral-content !bg-neutral-content/15">
                <HomeIcon class="size-4 shrink-0" />
                Home
            </NavLink>
            <NavLink href="/movies"
                     class="flex items-center gap-2.5 px-3 py-2 rounded text-sm text-neutral-content/60 hover:text-neutral-content hover:bg-neutral-content/10 transition-colors"
                     ActiveClass="!text-neutral-content !bg-neutral-content/15">
                <FilmIcon class="size-4 shrink-0" />
                Movies
            </NavLink>
            <NavLink href="/series"
                     class="flex items-center gap-2.5 px-3 py-2 rounded text-sm text-neutral-content/60 hover:text-neutral-content hover:bg-neutral-content/10 transition-colors"
                     ActiveClass="!text-neutral-content !bg-neutral-content/15">
                <TvIcon class="size-4 shrink-0" />
                Series
            </NavLink>
        </div>

        @if (DownloadService.Downloads.Count > 0)
        {
            <div class="border-t border-neutral-content/10 px-3 py-3 flex flex-col gap-2">
                <p class="text-xs text-neutral-content px-1 uppercase tracking-wider font-black">Downloads</p>
                @foreach (var dl in DownloadService.Downloads)
                {
                    <div class="flex flex-col gap-1 px-1">
                        <div class="flex items-center justify-between gap-1">
                            <span class="text-xs text-neutral-content/90 leading-snug line-clamp-2">@dl.Title</span>
                            @if (dl.Status == DownloadStatus.Downloading)
                            {
                                <button class="shrink-0 !cursor-pointer text-neutral-content/60 hover:text-neutral-content transition-colors"
                                        title="Cancel"
                                        @onclick="() => DownloadService.Cancel(dl.Id)">
                                    <XMarkIcon class="size-3.5" />
                                </button>
                            }
                            else
                            {
                                <button class="shrink-0 !cursor-pointer text-neutral-content/60 hover:text-neutral-content transition-colors"
                                        title="Dismiss"
                                        @onclick="() => DownloadService.Dismiss(dl.Id)">
                                    <XMarkIcon class="size-3.5" />
                                </button>
                            }
                        </div>
                        @if (dl.Status == DownloadStatus.Downloading)
                        {
                            @if (dl.Progress >= 0)
                            {
                                <div class="flex items-center gap-1.5">
                                    <progress class="progress h-1 flex-1 [&::-webkit-progress-value]:bg-red-500 [&::-moz-progress-bar]:bg-red-500" value="@dl.Progress" max="100"></progress>
                                    <span class="text-xs text-neutral-content/70 w-7 text-right shrink-0">@dl.Progress%</span>
                                </div>
                            }
                            else
                            {
                                <progress class="progress h-1 w-full [&::-webkit-progress-value]:bg-red-500 [&::-moz-progress-bar]:bg-red-500"></progress>
                            }
                        }
                        else
                        {
                            <span class="text-xs @(dl.Status == DownloadStatus.Completed ? "text-success" : "text-error")">
                                @dl.Status
                            </span>
                        }
                    </div>
                }
            </div>
        }

    </nav>

    <main class="flex-1 overflow-hidden bg-base-100">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!SettingsService.IsConfigured)
            Nav.NavigateTo("/setup");

        DownloadService.OnChanged += HandleDownloadChanged;
    }

    private void HandleDownloadChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DownloadService.OnChanged -= HandleDownloadChanged;
    }
}
