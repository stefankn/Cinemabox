@using Blazor.Heroicons.Outline
@inject SettingsService SettingsService
@inject ApiClient ApiClient

<div class="p-8 overflow-y-auto h-full">
    @if (_loading)
    {
        <div class="flex items-center justify-center h-full">
            <span class="loading loading-spinner loading-md text-base-content/30"></span>
        </div>
    }
    else if (_error is not null)
    {
        <div class="flex flex-col items-center justify-center h-full gap-3">
            <p class="text-sm text-error">@_error</p>
            <button class="btn btn-ghost btn-xs" @onclick="LoadAccountInfo">Retry</button>
        </div>
    }
    else if (_accountInfo is not null)
    {
        <div class="max-w-sm flex flex-col gap-4">
            <div>
                <p class="text-xs text-base-content/40 uppercase tracking-wider font-medium mb-3">Account</p>
                <div class="border border-base-300 rounded-lg divide-y divide-base-300">
                    <div class="flex items-center justify-between px-4 py-2.5">
                        <span class="text-sm text-base-content/60">Username</span>
                        <span class="text-sm font-medium">@SettingsService.Settings?.Username</span>
                    </div>
                    <div class="flex items-center justify-between px-4 py-2.5">
                        <span class="text-sm text-base-content/60">Status</span>
                        <span class="badge badge-sm @(_accountInfo.Status == "Active" ? "badge-success" : "badge-error")">
                            @_accountInfo.Status
                        </span>
                    </div>
                    <div class="flex items-center justify-between px-4 py-2.5">
                        <span class="text-sm text-base-content/60">Expires</span>
                        <span class="text-sm font-medium">@FormatExpDate(_accountInfo.ExpDate)</span>
                    </div>
                </div>
            </div>
            <div class="flex justify-end">
                <button class="btn btn-ghost btn-sm text-error hover:bg-error/10" @onclick="() => _showConfirm = true">
                    Reset configuration
                </button>
            </div>
        </div>
    }
</div>

<dialog class="modal @(_showConfirm ? "modal-open" : "")">
    <div class="modal-box max-w-sm">
        <h3 class="font-semibold text-base">Reset configuration?</h3>
        <p class="text-sm text-base-content/60 mt-2">
            Your provider URL, username, and password will be deleted.
            You'll need to go through setup again.
        </p>
        <div class="modal-action">
            <button class="btn btn-ghost btn-sm" @onclick="() => _showConfirm = false">Cancel</button>
            <button class="btn btn-error btn-sm" @onclick="ResetConfig">Reset</button>
        </div>
    </div>
    <div class="modal-backdrop" @onclick="() => _showConfirm = false"></div>
</dialog>

@code {
    [Parameter] public EventCallback OnShowSetup { get; set; }

    private bool _loading = true;
    private bool _showConfirm;
    private AccountInfoResponse? _accountInfo;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccountInfo();
    }

    private async Task LoadAccountInfo()
    {
        _loading = true;
        _error = null;
        try
        {
            _accountInfo = await ApiClient.GetAccountInfoAsync();
        }
        catch
        {
            _error = "Failed to load account information.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResetConfig()
    {
        SettingsService.Reset();
        await OnShowSetup.InvokeAsync();
    }

    private static string FormatExpDate(string expDate)
    {
        if (long.TryParse(expDate, out var unix))
            return DateTimeOffset.FromUnixTimeSeconds(unix).LocalDateTime.ToString("MMM d, yyyy");
        return expDate;
    }
}
