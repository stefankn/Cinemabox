@* Reusable label/value row for metadata tables *@
<div class="flex gap-3 px-4 py-2.5">
    <span class="text-xs text-base-content/40 w-16 shrink-0 pt-px">@Label</span>
    <span class="text-xs text-base-content/80 leading-relaxed">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string? Value { get; set; }
}
